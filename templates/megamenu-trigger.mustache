{{!
    @template theme_boost_union/megamenu-trigger

    This template renders the corner trigger which opens the mega menu overlay (the 'Mega menu' navigation layout
    of Boost Union). In the combo trigger mode it shows a labelled button; in the hidden trigger mode (signalled by
    the theme-megamenu-triggerhidden class on the wrapper) only the bare icon is shown.

    Context variables required for this template:
    * none

    Example context (json):
    {
    }
}}
<div class="bu-megamenu-corner d-print-none">
    {{! The logo links to the configured home URL (Home / Dashboard / My courses depending on the site's default
        home page setting), providing a one-click path to the main page while the navigation is hidden. }}
    <a class="bu-megamenu-corner__logo" title="{{{ sitename }}}" data-region="site-home-link"
        href="{{#alternativelogolinkurl}}{{{alternativelogolinkurl}}}{{/alternativelogolinkurl}}{{^alternativelogolinkurl}}{{{ config.homeurl }}}{{/alternativelogolinkurl}}">
        {{#navlogourl}}
            <img src="{{navlogourl}}" alt="{{sitename}}">
        {{/navlogourl}}
        {{^navlogourl}}
            <span class="bu-megamenu-corner__sitename">{{{ sitename }}}</span>
        {{/navlogourl}}
    </a>
    {{! The smart menu items configured for the 'Menu' (menu bar) location are shown in the cluster, providing a
        place for important quick-access icons (e.g. Home, Dashboard) while the navigation is otherwise hidden. }}
    {{#menubar}}
        <div class="bu-megamenu-corner__menubar">
            {{> core/moremenu}}
        </div>
    {{/menubar}}
    {{! The edit mode switch is kept beside the trigger so editing can be turned on while the navigation is hidden.
        The output is kept on a single line with no surrounding whitespace so the :empty CSS rule can hide it for
        users without an edit switch (e.g. students). }}
    <div class="bu-megamenu-corner__editswitch">{{{ output.edit_switch }}}</div>
    <button type="button" id="theme_boost_union-megamenu-trigger" class="bu-megamenu-trigger"
        aria-haspopup="dialog" aria-controls="theme_boost_union-megamenu" aria-expanded="false"
        title="{{#str}}megamenuopen, theme_boost_union{{/str}}">
        <i class="fa-solid fa-bars" aria-hidden="true"></i>
        <span class="bu-megamenu-trigger__label">{{#str}}megamenuheading, theme_boost_union{{/str}}</span>
    </button>
</div>
